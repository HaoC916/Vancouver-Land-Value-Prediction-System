# Backend API base URL used by the React frontend.
#
# Local dev (npm run dev) reads .env.development, which points at the FastAPI
# server on http://127.0.0.1:8000.
#
# In production, set VITE_API_BASE in the Vercel project's Environment Variables
# to the deployed backend, e.g.
#   https://<user>-vancouver-land-value-api.hf.space
VITE_API_BASE=http://127.0.0.1:8000
